---
import { Image } from "astro:assets";
import type { PhotoProps } from "@types";

interface Props {
  photos: PhotoProps[];
  items_per_slide?: number;
}

const { photos, items_per_slide = 1 } = Astro.props;

// Generate random tilts for each photo (between 5 and 30 degrees, random direction)
const tilts = photos.map(() => (Math.random() > 0.5 ? 1 : -1) * (Math.random() * 25 + 5));
---


<div
  class="relative"
  id="carousel"
  data-items-per-slide={items_per_slide}
  aria-roledescription="carousel"
  aria-label="Photo gallery carousel"
>
  <!-- Track -->
  <div
    class="flex transition-transform duration-700 ease-in-out py-20"
    id="carousel-track"
    aria-live="polite"
  >


    {
      photos.map((photo, i) => (
        <div
          class="carousel-slide relative shrink-0 transition-all duration-700 ease-in-out"
          style={`width: ${100 / items_per_slide}%`}
          role="group"
          data-tilt={tilts[i]}
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${photos.length}: ${photo.title}`}
        >
          <a
            href={`/gallery/${photo.slug}`}
            tabindex={i === 0 ? "0" : "-1"}
            class="carousel-content block transition-all duration-700 ease-in-out origin-center"
          >
            <div class="relative overflow-hidden rounded-xl shadow-2xl">
              <Image
                src={photo.image}
                alt={photo.title}
                width={800}
                height={500}
                class="h-72 w-full object-cover sm:h-80 md:h-96"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent" />
            </div>
            <div class="absolute bottom-6 left-6 right-16">
              {photo.category && (
                <span class="mb-2 inline-block rounded-full bg-primary/90 px-3 py-1 text-xs font-medium text-white">
                  {photo.category}
                </span>
              )}
              <h3 class="font-serif text-2xl font-bold text-white drop-shadow">
                {photo.title}
              </h3>
              {photo.date && (
                <p class="mt-1 text-sm text-white/70">{photo.date}</p>
              )}
            </div>
          </a>
        </div>
      ))
    }

  </div>

  <!-- Prev button -->
  <button
    type="button"
    id="carousel-prev"
    class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
    aria-label="Previous photo"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m15 18-6-6 6-6"></path>
    </svg>
  </button>

  <!-- Next button -->
  <button
    type="button"
    id="carousel-next"
    class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
    aria-label="Next photo"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </button>

  <!-- Dot indicators -->
  <div
    class="absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1.5"
    id="carousel-dots"
    role="tablist"
    aria-label="Slide indicators"
  >
    {
      photos.map((photo, i) => (
        <button
          type="button"
          role="tab"
          class={`h-1.5 rounded-full transition-all duration-300 ${i === 0 ? "w-5 bg-white" : "w-1.5 bg-white/40"}`}
          data-index={String(i)}
          aria-label={`Go to slide ${i + 1}: ${photo.title}`}
          aria-selected={i === 0 ? "true" : "false"}
        />
      ))
    }
  </div>

</div>

<script>
  const track = document.getElementById("carousel-track") as HTMLElement;
  const slides = track.querySelectorAll("[role='group']");
  const dots = document.querySelectorAll<HTMLButtonElement>(
    "#carousel-dots button",
  );
  const prevBtn = document.getElementById("carousel-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("carousel-next") as HTMLButtonElement;
  const carousel = document.getElementById("carousel") as HTMLElement;
  const slideLinks =
    track.querySelectorAll<HTMLAnchorElement>("a[tabindex]");

  const itemsPerSlide = Number(carousel.dataset.itemsPerSlide) || 1;

  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval> | undefined;

  function goTo(index: number) {
    const totalSlides = slides.length;
    
    current = index;
    if (current < 0) current = totalSlides - 1;
    if (current >= totalSlides) current = 0;

    // Center the active slide
    const slideWidthPercent = 100 / itemsPerSlide;
    const centerOffset = (itemsPerSlide - 1) / 2;
    const targetTranslate = -(current - centerOffset) * slideWidthPercent;
    track.style.transform = `translateX(${targetTranslate}%)`;

    // Update individual slide styles
    slides.forEach((slide, i) => {
      const slideEl = slide as HTMLElement;
      const content = slideEl.querySelector(".carousel-content") as HTMLElement;
      const isActive = i === current;
      const tilt = slideEl.dataset.tilt;
      
      // Calculate distance from currently selected slide
      const distance = Math.abs(i - current);
      
      if (isActive) {
        content.style.transform = "scale(1) rotate(0deg)";
        slideEl.style.opacity = "1";
        slideEl.style.zIndex = "20";
        slideEl.classList.remove("pointer-events-none");
      } else {
        content.style.transform = `scale(0.8) rotate(${tilt}deg)`;
        
        // Decrease opacity symmetrically as it gets further from the selected slide
        const opacity = Math.max(0.05, 1 - distance * 0.35);
        slideEl.style.opacity = String(opacity);
        slideEl.style.zIndex = String(10 - distance);
        slideEl.classList.add("pointer-events-none");
      }
    });


    dots.forEach((dot, i) => {
      const active = i === current;
      dot.classList.toggle("w-5", active);
      dot.classList.toggle("bg-white", active);
      dot.classList.toggle("w-1.5", !active);
      dot.classList.toggle("bg-white/40", !active);
      dot.setAttribute("aria-selected", String(active));
    });

    slideLinks.forEach((link, i) => {
      link.setAttribute("tabindex", i === current ? "0" : "-1");
    });
  }

  // Initial call to set styles
  goTo(0);


  function startAutoplay() {
    autoplayTimer = setInterval(() => goTo(current + 1), 4000);
  }

  function stopAutoplay() {
    clearInterval(autoplayTimer);
  }

  prevBtn.addEventListener("click", () => {
    stopAutoplay();
    goTo(current - 1);
    startAutoplay();
  });

  nextBtn.addEventListener("click", () => {
    stopAutoplay();
    goTo(current + 1);
    startAutoplay();
  });

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      stopAutoplay();
      goTo(Number(dot.dataset.index));
      startAutoplay();
    });
  });

  carousel.addEventListener("mouseenter", stopAutoplay);
  carousel.addEventListener("mouseleave", startAutoplay);

  carousel.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "ArrowLeft") {
      stopAutoplay();
      goTo(current - 1);
      startAutoplay();
    } else if (e.key === "ArrowRight") {
      stopAutoplay();
      goTo(current + 1);
      startAutoplay();
    }
  });

  startAutoplay();
</script>
