---
import { Image } from "astro:assets";
import type { PhotoProps } from "@types";

interface Props {
  photos: PhotoProps[];
  items_per_slide?: number;
}

const { photos } = Astro.props;

const extendedPhotos = [photos[photos.length - 1], ...photos, photos[0]];
---

<div
  class="carousel-root fixed inset-0 -z-20 overflow-hidden"
  id="carousel"
  data-total-original={photos.length}
  aria-hidden="true"
>
  <div class="carousel-track flex h-full w-full" id="carousel-track">
    {
      extendedPhotos.map((photo) => (
        <div class="carousel-slide relative h-full w-full shrink-0">
          <Image
            src={photo.image}
            alt=""
            width={2400}
            height={1600}
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .carousel-track {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    will-change: transform;
  }
</style>

<script>
  const track = document.getElementById("carousel-track") as HTMLElement;
  const carousel = document.getElementById("carousel") as HTMLElement;
  const originalLength = Number(carousel.dataset.totalOriginal) || 0;

  let current = 1;
  let isMoving = false;

  function goTo(index: number, immediate = false) {
    if (isMoving && !immediate) return;
    current = index;

    if (immediate) {
      track.style.transition = "none";
    } else {
      track.style.transition = "transform 1500ms ease-in-out";
      isMoving = true;
    }

    track.style.transform = `translateX(${-current * 100}%)`;

    if (!immediate) {
      window.setTimeout(() => {
        if (current >= originalLength + 1) {
          goTo(1, true);
        } else if (current < 1) {
          goTo(originalLength, true);
        }
        isMoving = false;
      }, 1500);
    }
  }

  goTo(current, true);

  window.setInterval(() => {
    if (!isMoving) goTo(current + 1);
  }, 6000);

  window.addEventListener("resize", () => {
    goTo(current, true);
  });
</script>
