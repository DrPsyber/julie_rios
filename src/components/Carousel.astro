---
import { Image } from "astro:assets";
import type { PhotoProps } from "@types";

interface Props {
  photos: PhotoProps[];
  items_per_slide?: number;
}

const { photos } = Astro.props;
---

<div
  class="carousel-root fixed inset-0 z-0 overflow-hidden"
  id="carousel"
  data-total={photos.length}
  aria-hidden="true"
>
  {
    photos.map((photo, i) => (
      <div
        class:list={[
          "carousel-slide absolute inset-0",
          i === 0 ? "is-active" : "",
        ]}
        data-index={i}
        style={`--zoom-delay: -${(i * 4) % 20}s`}
      >
        <Image
          src={photo.image}
          alt=""
          width={2400}
          height={1600}
          class="h-full w-full object-cover"
          loading={i === 0 ? "eager" : "lazy"}
        />
      </div>
    ))
  }
</div>

<style>
  .carousel-root {
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
    mask-composite: intersect;
  }

  .carousel-slide {
    opacity: 0;
    transition: opacity 1500ms ease-in-out;
    will-change: opacity;
  }

  .carousel-slide.is-active {
    opacity: 1;
  }

  .carousel-slide :global(img) {
    animation: slow-zoom 20s ease-in-out infinite alternate;
    animation-delay: var(--zoom-delay, 0s);
    transform-origin: center;
  }

  @keyframes slow-zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.12);
    }
  }
</style>

<script>
  const carousel = document.getElementById("carousel") as HTMLElement;
  const slides = Array.from(
    carousel.querySelectorAll<HTMLElement>(".carousel-slide"),
  );
  const total = slides.length;

  let current = 0;

  function activate(next: number) {
    const prev = current;
    current = (next + total) % total;
    slides[prev].classList.remove("is-active");
    slides[current].classList.add("is-active");
  }

  window.setInterval(() => {
    activate(current + 1);
  }, 6000);
</script>
