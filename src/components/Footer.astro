---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;

const { author, socialLinks } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  class="relative z-10 mx-auto mt-24 flex w-full max-w-3xl flex-col items-center gap-6 border-t border-white/10 px-5 pt-10 pb-12 text-center"
>
  {
    socialLinks.length > 0 && (
      <ul class="flex flex-wrap justify-center gap-x-8 gap-y-2">
        {socialLinks.map(({ text, href }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="font-display text-xs tracking-widest uppercase text-white/65 transition-colors hover:text-primary"
            >
              {text}
            </a>
          </li>
        ))}
      </ul>
    )
  }
  <p class="font-display text-[0.65rem] tracking-[0.4em] uppercase text-white/45">
    {author} · {currentYear}
  </p>
  <p class="font-body text-xs italic text-white/35">
    Site by Moisés Machuca
  </p>
</footer>
