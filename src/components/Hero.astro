---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { specialty, summary, email } = Astro.props;
---

<section
  id="#hero"
  class="reveal-section py-32 md:py-40"
>
  <div class="mb-20 flex items-baseline gap-6 text-white/60">
    <span
      class="font-script text-2xl leading-none text-primary"
      aria-hidden="true">—</span
    >
    <span
      class="font-display text-xs tracking-[0.32em] uppercase text-white/55"
    >
      Atelier
    </span>
  </div>

  <h2
    class="mb-12 font-display italic text-[clamp(3rem,11vw,8.5rem)] leading-[0.92] tracking-tightest text-white"
  >
    {specialty}.
  </h2>

  <p
    class="mb-16 max-w-xl font-body text-xl leading-[1.7] text-white/75 md:text-[1.4rem] md:leading-[1.6]"
  >
    {summary}
  </p>

  <a
    class="group inline-flex items-baseline gap-3 font-display text-xs tracking-widest uppercase text-white transition-colors hover:text-primary"
    href={`mailto:${email}`}
  >
    <span class="relative">
      Inquire
      <span
        class="absolute -bottom-1 left-0 h-px w-full origin-left scale-x-100 bg-current transition-transform duration-500 group-hover:scale-x-50"
      ></span>
    </span>
    <span class="font-body text-base normal-case tracking-normal italic text-white/60 group-hover:text-primary"
      >{email}</span
    >
  </a>
</section>
