---
import Menu from "@icons/Menu.astro";
import type { HeaderProps } from "@types";

type Props = HeaderProps;

const { navLinks } = Astro.props;
---

<header
  class="fixed inset-x-0 top-0 z-50 flex items-center justify-between px-6 py-6 text-white sm:px-10"
>
  <a
    href="/"
    aria-label="Home"
    class="font-display text-xs tracking-widest uppercase text-white/85 transition-colors hover:text-white"
  >
    J · R
  </a>

  <button
    type="button"
    id="menu-button"
    class="px-1.5 text-white/80 sm:hidden"
    aria-expanded="false"
    aria-controls="main-menu"
  >
    <Menu />
  </button>

  <nav
    class="absolute top-16 right-6 hidden rounded-sm border border-white/10 bg-black/60 px-5 py-4 text-white/85 backdrop-blur-md sm:static sm:block sm:border-0 sm:bg-transparent sm:p-0 sm:backdrop-blur-none"
    id="main-menu"
  >
    <ul class="gap-10 sm:flex">
      {
        navLinks.map((link) => (
          <li>
            <a
              class="nav-item block py-1 font-display text-xs tracking-widest uppercase text-white/75 transition-colors hover:text-white"
              href={link.href}
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const button = document.querySelector("#menu-button");
  const menu = document.querySelector("#main-menu");
  const navItems = document.querySelectorAll("#main-menu > ul > li > a");

  const toggleMenu = () => {
    menu?.classList.toggle("hidden");
    const isHidden = menu?.classList.contains("hidden");
    button?.setAttribute("aria-expanded", `${!isHidden}`);
  };

  button?.addEventListener("click", toggleMenu);
  navItems.forEach((item) => {
    item?.addEventListener("click", toggleMenu);
  });
</script>
