---
import { Image } from "astro:assets";
import type { PhotoProps } from "@types";

interface Props {
  photo: PhotoProps;
  index: number;
}

const { photo, index: arrayIndex } = Astro.props;
---

<div
  class="group relative block overflow-hidden rounded-xl border border-neutral/20 bg-black/40 backdrop-blur-sm transition-all duration-300 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/10 cursor-move"
  data-photo-item
  data-slug={photo.slug}
>
  <div class="relative overflow-hidden h-48">
    <Image
      src={photo.image}
      alt={photo.title}
      width={400}
      height={300}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-60 group-hover:opacity-80"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
    
    <div class="absolute bottom-3 left-3 right-3">
       <p class="font-serif text-sm font-semibold text-white truncate">
         {photo.title}
       </p>
       <p class="text-[10px] text-neutral/70 uppercase tracking-wider">
         {photo.category}
       </p>
    </div>
  </div>

  <div class="p-4 space-y-4">
    <div class="flex items-center justify-between">
      <label class="flex items-center gap-2 cursor-pointer group/label">
        <div class="relative flex items-center">
            <input 
                type="checkbox" 
                checked={photo.featured} 
                class="peer sr-only photo-featured" 
            />
            <div class="h-5 w-9 rounded-full bg-neutral/30 border border-neutral/20 transition-colors peer-checked:bg-primary/40 peer-checked:border-primary/60"></div>
            <div class="absolute left-1 top-1 h-3 w-3 rounded-full bg-white/80 transition-transform peer-checked:translate-x-4"></div>
        </div>
        <span class="text-xs font-medium text-neutral group-hover/label:text-white transition-colors">Featured</span>
      </label>

      <div class="flex items-center gap-2">
        <label class="text-[10px] text-neutral/60 font-medium">Index</label>
        <input 
          type="number" 
          value={photo.index} 
          class="w-16 bg-black/60 border border-neutral/30 rounded px-2 py-1 text-xs text-white focus:border-primary/60 focus:outline-none photo-index"
        />
      </div>
    </div>
  </div>
</div>
