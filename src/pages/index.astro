---
import { SITE_CONTENT } from "@config";
import Hero from "@components/Hero.astro";
import Layout from "@layouts/Layout.astro";

import About from "@components/About.astro";
import Carousel from "@components/Carousel.astro";

import "../styles/global.css";

const [firstName, ...rest] = SITE_CONTENT.hero.name.split(" ");
const lastName = rest.join(" ");
---

<Layout>
  <Carousel
    photos={SITE_CONTENT.photos
      .filter((photo) => photo.featured)
      .sort((a, b) => (a.index ?? 0) - (b.index ?? 0))}
  />

  <div
    class="dim-overlay pointer-events-none fixed inset-0 z-1 bg-black opacity-0"
    id="dim-overlay"
  >
  </div>

  <span
    class="dateline fixed top-1/2 left-4 z-20 hidden -translate-y-1/2 -rotate-90 origin-left font-display text-[0.65rem] tracking-[0.4em] uppercase text-white/45 sm:block"
    aria-hidden="true"
  >
    Dallas · Artist · Est. 2018
  </span>

  <section
    class="open-hero relative z-10 flex h-screen flex-col items-start justify-end px-4 pb-10 sm:px-12 sm:pb-14"
  >
    <span
      class="mb-6 font-display text-[0.7rem] tracking-[0.4em] uppercase text-white/55"
    >
      <span class="inline-block w-12 align-middle border-t border-white/30"
      ></span>
      <span class="ml-3">{SITE_CONTENT.hero.specialty}</span>
    </span>
    <h1
      class="hero-title font-display font-black leading-[0.95] tracking-tightest text-white"
    >
      <span class="-ml-[0.3em] block text-[clamp(3rem,13vw,11rem)]"
        >{firstName}</span
      >
      <span
        class="ml-[0.3em] mt-[0.05em] block text-[clamp(2.4rem,11vw,9rem)] italic font-extrabold text-white/85"
        >{lastName}</span
      >
    </h1>
  </section>

  <div class="relative z-10">
    <Hero {...SITE_CONTENT.hero} />

    <hr class="mx-auto my-8 h-px w-16 border-0 bg-white/15" />

    <div
      class="reveal-section flex flex-col items-center gap-3 pb-24 text-center"
    >
      <span
        class="font-display text-[0.7rem] tracking-[0.4em] uppercase text-white/45"
      >
        {SITE_CONTENT.hero.summary}
      </span>
      <a
        href="/gallery"
        class="group inline-flex items-baseline gap-3 font-display text-xs tracking-widest uppercase text-white transition-colors hover:text-primary"
      >
        <span class="relative">
          View the Gallery
          <span
            class="absolute -bottom-1 left-0 h-px w-full origin-left scale-x-100 bg-current transition-transform duration-500 group-hover:scale-x-50"
          ></span>
        </span>
      </a>
    </div>

    <About {...SITE_CONTENT.about} name={SITE_CONTENT.hero.name} />
  </div>
</Layout>

<style>
  .hero-title {
    text-shadow:
      0 2px 6px rgba(0, 0, 0, 0.55),
      0 8px 24px rgba(0, 0, 0, 0.55),
      0 18px 48px rgba(0, 0, 0, 0.45);
  }
  .hero-title > span {
    display: block;
    opacity: 0;
    transform: translateY(0.6em);
    filter: blur(8px);
    animation: hero-rise 1300ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  .hero-title > span:nth-child(1) {
    animation-delay: 200ms;
  }
  .hero-title > span:nth-child(2) {
    animation-delay: 600ms;
  }
  @keyframes hero-rise {
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .reveal-section {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 1100ms cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 1100ms cubic-bezier(0.2, 0.7, 0.2, 1);
    will-change: opacity, transform;
  }
  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const overlay = document.getElementById("dim-overlay") as HTMLElement;
  const updateDim = () => {
    const ratio = window.scrollY / window.innerHeight;
    overlay.style.opacity = String(Math.min(0.85, ratio * 0.85));
  };
  updateDim();
  window.addEventListener("scroll", updateDim, { passive: true });
  window.addEventListener("resize", updateDim);

  const reveal = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          reveal.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.18 },
  );
  document
    .querySelectorAll(".reveal-section")
    .forEach((el) => reveal.observe(el));
</script>
