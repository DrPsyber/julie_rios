---
import { SITE_CONTENT } from "@config";
import Layout from "@layouts/Layout.astro";
import GalleryGrid from "@components/GalleryGrid.astro";

import "../../styles/global.css";

const { photos } = SITE_CONTENT;

const categories = [...new Set(photos.map((p) => p.category).filter(Boolean))];
---

<Layout wide={true}>
  <section class="py-24">
    <div class="mb-14">
      <a
        href="/"
        class="mb-6 inline-flex items-center gap-1.5 text-sm text-neutral transition-colors hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Home
      </a>
      <h1
        class="font-serif text-5xl font-bold tracking-tighter text-white md:text-6xl"
      >
        Gallery
      </h1>
      {
        categories.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2" id="filter-container">
            <button
              data-filter="all"
              class="filter-btn active rounded-full border border-primary bg-primary/20 px-3 py-1 text-xs font-medium text-primary transition-all hover:bg-primary/30 cursor-pointer"
            >
              All
            </button>
            <button
              data-filter="featured"
              class="filter-btn rounded-full border border-neutral/30 px-3 py-1 text-xs font-medium text-neutral transition-all hover:border-neutral/50 hover:text-white cursor-pointer"
            >
              Featured
            </button>
            {categories.map((cat) => (
              <button
                data-filter={cat}
                class="filter-btn rounded-full border border-neutral/30 px-3 py-1 text-xs font-medium text-neutral transition-all hover:border-neutral/50 hover:text-white cursor-pointer"
              >
                {cat}
              </button>
            ))}
          </div>
        )
      }
    </div>

    <GalleryGrid photos={photos} />
  </section>
</Layout>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const galleryItems = document.querySelectorAll('[data-category]');

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter');

      // Update active button state
      filterButtons.forEach(btn => {
        btn.classList.remove('active', 'border-primary', 'bg-primary/20', 'text-primary');
        btn.classList.add('border-neutral/30', 'text-neutral');
      });
      button.classList.add('active', 'border-primary', 'bg-primary/20', 'text-primary');
      button.classList.remove('border-neutral/30', 'text-neutral');

      // Filter gallery items
      galleryItems.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        const isFeatured = item.getAttribute('data-featured') === 'true';

        if (filter === 'all') {
          (item as HTMLElement).style.display = '';
        } else if (filter === 'featured') {
          (item as HTMLElement).style.display = isFeatured ? '' : 'none';
        } else if (itemCategory === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
